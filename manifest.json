{
  "manifest_version": 3,
  "name": "qassist",
  "version": "0.1.0",
  "description": "Personal QA assistant",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "cookies",
    "sidePanel",
    "identity"
  ],
  "oauth2": {
    "client_id": "1010123517519-fb6mk9tha9diea4h1lbu2svpnrmckcgg.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/drive.file",
      "openid",
      "email"
    ]
  },
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content/error-capture.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
