{
  "manifest_version": 3,
  "name": "qassist",
  "version": "0.1.0",
  "description": "Personal QA assistant",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "webRequest",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "dist/background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "src/icons/icon-16.png",
      "48": "src/icons/icon-48.png",
      "128": "src/icons/icon-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["dist/content/content-script.js"],
      "run_at": "document_start"
    }
  ],
  "options_ui": {
    "page": "src/options/options.html",
    "open_in_tab": true
  },
  "web_accessible_resources": [
    {
      "resources": ["dist/content/error-capture.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
